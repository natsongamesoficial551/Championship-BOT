# ── LOCAL ────────────────────────────────────────────────────────
# Renomeie para .env e cole seu token abaixo.
DISCORD_TOKEN=seu_token_aqui

# ── RENDER ───────────────────────────────────────────────────────
# Não use .env no Render. Configure em:
# Dashboard > seu serviço > Settings > Environment Variables
# Adicione: DISCORD_TOKEN = seu_token_aqui
